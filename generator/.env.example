# Secrets and local overrides only.
# Non-secret generator settings live in src/common/config/settings/.

# Optional local overrides:
# API_MODE=DEV
# API_PORT=8010
# AUTH_CONTEXT_URL=http://auth-service:8030/v1/auth/context

# LLM / external APIs
OPENAI_API_KEY=sk-example
DEEPSEEK_API_KEY=
GIGACHAT_API_KEY=

# Optional generated file storage overrides:
# GENERATED_FILE_DB_PATH=./data/generated_files.sqlite3
# GENERATED_FILE_TTL_SECONDS=10800

# Optional outbound proxy with credentials
# PROXY is used directly by the backend LLM HTTP client.
PROXY=socks5h://user:password@host:port
ALL_PROXY=socks5h://user:password@host:port
HTTP_PROXY=socks5h://user:password@host:port
HTTPS_PROXY=socks5h://user:password@host:port
NO_PROXY=localhost,127.0.0.1,nginx,frontend,backend-vn1,keycloak,xray
all_proxy=socks5h://user:password@host:port
http_proxy=socks5h://user:password@host:port
https_proxy=socks5h://user:password@host:port
no_proxy=localhost,127.0.0.1,nginx,frontend,backend-vn1,keycloak,xray
