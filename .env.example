# Secrets only. Non-secret project settings live in src/app/config/setting.toml.

# LLM / external APIs
OPENAI_API_KEY=sk-example
DEEPSEEK_API_KEY=
GIGACHAT_API_KEY=

# Auth / Keycloak secrets
AUTH_CLIENT_SECRET=
KEYCLOAK_ADMIN_PASSWORD=change-me

# Optional outbound proxy with credentials
PROXY=socks5h://user:password@host:port
ALL_PROXY=socks5h://user:password@host:port
HTTP_PROXY=socks5h://user:password@host:port
HTTPS_PROXY=socks5h://user:password@host:port
all_proxy=socks5h://user:password@host:port
http_proxy=socks5h://user:password@host:port
https_proxy=socks5h://user:password@host:port
