# =============================================================================
# API
# =============================================================================
API_PORT=8010
API_MODE=PROD
API_ROOT=/api
API_LOG_PATH=./logs
API_LOG_LEVEL=INFO
API_IS_READONLY=FALSE

# Optional rate limits. The code reads RATE_LIMIT_<NAME>, for example:
# RATE_LIMIT_PUBLIC=5/minute
# RATE_LIMIT_USER=5/minute

# =============================================================================
# Auth / Keycloak
# =============================================================================
AUTH_ENABLED=TRUE
AUTH_ISSUER_URL=http://localhost:8080/keycloak/realms/vn1
AUTH_JWKS_URL=http://localhost:8080/keycloak/realms/vn1/protocol/openid-connect/certs
AUTH_TOKEN_URL=http://localhost:8080/keycloak/realms/vn1/protocol/openid-connect/token
AUTH_CLIENT_ID=vn1-api
AUTH_CLIENT_SECRET=
AUTH_AUDIENCE=
AUTH_REQUIRED_ROLES=["vn1-user"]

# Used by docker-compose for the Keycloak container and backend issuer URL.
KEYCLOAK_HOSTNAME=http://localhost:8080/keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admindeor

# =============================================================================
# LLM / External APIs
# =============================================================================
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GIGACHAT_API_KEY=

# Optional outbound proxy for backend/LLM calls.
PROXY=
ALL_PROXY=
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,nginx,backend-vn1,keycloak
all_proxy=
http_proxy=
https_proxy=
no_proxy=localhost,127.0.0.1,nginx,backend-vn1,keycloak

# =============================================================================
# Frontend
# =============================================================================
# Used only for local Vite builds/dev server. In docker/nginx, /api is correct.
VITE_API_BASE_URL=/api

# =============================================================================
# Docker build args / Makefile
# =============================================================================
PANDOC_VERSION=3.8
PORT=8010
FRONTEND_PORT=5173
CERT_DOMAIN=ai-bot.vn1.ru
