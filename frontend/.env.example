# Public frontend API routes.
# Use same-origin paths so the browser works both locally and in containers.

# Generic backend requests go through api-gateway.
API_BASE_URL=/api

# Generator scenario requests go through the public nginx route to generator API.
GENERATOR_API_BASE_URL=/generator-api

# Auth remains separate.
AUTH_BASE_URL=/auth

# Local Vite dev proxy targets.
DEV_PROXY_API_TARGET=http://localhost:8000
DEV_PROXY_GENERATOR_API_TARGET=http://localhost:8010
DEV_PROXY_AUTH_TARGET=http://localhost:8030
